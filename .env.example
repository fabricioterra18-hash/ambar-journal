# ── Supabase (OBRIGATÓRIO) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: usado por jobs server-only que precisam ignorar RLS. Nunca expor no cliente.
# SUPABASE_SERVICE_ROLE_KEY=

# ── IA (provider único — Gemini) ──
# Chave do Google Generative AI. Aceita também GOOGLE_API_KEY ou GOOGLE_GENERATIVE_AI_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Opcional: usar OpenAI em vez de Gemini. Se setado, sobrescreve o provider.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# AI_MODEL=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feedback por email (OPCIONAL — sem isso, feedback fica só no Supabase) ──
# RESEND_API_KEY=
# RESEND_FROM="Âmbar Feedback <noreply@seudominio.com>"
